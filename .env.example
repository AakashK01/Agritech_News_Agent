# Storage (at least one must be true)
AGRITECH_EXCEL_ENABLED=true
AGRITECH_POSTGRES_ENABLED=false

# --- PostgreSQL (required when AGRITECH_POSTGRES_ENABLED=true) ---
# Local app connecting to Postgres on your Mac (native install or Docker with port mapped)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agritech
DB_USER=postgres
DB_PASS=secret
DB_SCHEMA=agritech
DB_SSL=false
# Optional pool tuning (defaults shown)
DB_MAX_POOL_SIZE=10
DB_MIN_POOL_SIZE=2
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000

# Ollama
AGRITECH_AI_ENABLED=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# Scheduling (orchestrator runs all enabled jobs sequentially each cycle)
AGRITECH_DEFAULT_INTERVAL_MS=604800000
JOB_STAGGER_DELAY_MS=1200000
AGRITECH_RUN_ONCE=false

# Sources (each job runs in order with JOB_STAGGER_DELAY_MS between them)
AGRITECH_AGFUNDER_ENABLED=true
AGRITECH_INC42_ENABLED=false
AGRITECH_INC42_BROWSER_ENABLED=true

# Caps
MAX_ITEMS_SCANNED_PER_RUN=50
MAX_NEW_ROWS_PER_RUN=20
MAX_SECTIONS_PER_RUN=10

# Browser fallback (optional — for JS-rendered sources)
AGRITECH_BROWSER_FALLBACK_ENABLED=false
AGRITECH_PROFILES_ROOT=./profiles

# Paths
AGRITECH_RUNS_DIR=./data/runs
AGRITECH_URL_CONTENT_INDEX=./data/url-content-index.json
AGRITECH_SECTION_SNAPSHOTS=./data/section-snapshots.json
