# Copy to .env and adjust: cp .env.example .env

# --- Storage (at least one must be true) ---
AGRITECH_EXCEL_ENABLED=true
AGRITECH_POSTGRES_ENABLED=true
AGRITECH_AI_ENABLED=true

# --- Sources (Inc42 runs first, then AgFunder after JOB_STAGGER_DELAY_MS) ---
AGRITECH_INC42_ENABLED=true
AGRITECH_INC42_BROWSER_ENABLED=true
AGRITECH_AGFUNDER_ENABLED=true

# --- Scheduling ---
# Time between full orchestrator cycles (604800000 = 7 days)
AGRITECH_DEFAULT_INTERVAL_MS=604800000
# Pause between jobs in one cycle (120000 = 2 minutes). Inc42 → wait → AgFunder
JOB_STAGGER_DELAY_MS=120000
# true = run one cycle and exit; false = keep scheduler running
AGRITECH_RUN_ONCE=false

# --- Browser ---
# Inc42 Datalabs feed needs headed Chrome locally (npm run inc42:login). Not supported in Docker app container.
AGRITECH_BROWSER_FALLBACK_ENABLED=false
AGENT_BROWSER_HEADED=true
AGRITECH_PROFILES_ROOT=./profiles

# --- PostgreSQL (required when AGRITECH_POSTGRES_ENABLED=true) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agritech
DB_USER=postgres
DB_PASS=secret
DB_SCHEMA=agritech
DB_SSL=false
DB_MAX_POOL_SIZE=10
DB_MIN_POOL_SIZE=2
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000
POSTGRES_HOST_PORT=5432

# --- Ollama ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# --- Caps ---
MAX_ITEMS_SCANNED_PER_RUN=50
MAX_NEW_ROWS_PER_RUN=20
MAX_SECTIONS_PER_RUN=10

# --- Paths ---
AGRITECH_RUNS_DIR=./data/runs
AGRITECH_URL_CONTENT_INDEX=./data/url-content-index.json
AGRITECH_SECTION_SNAPSHOTS=./data/section-snapshots.json
