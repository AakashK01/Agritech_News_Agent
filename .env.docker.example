# Copy to .env for docker compose: cp .env.docker.example .env
# Note: Inc42 browser crawl must run on the host (npm run dev), not inside the app container.

# --- Storage ---
AGRITECH_EXCEL_ENABLED=true
AGRITECH_POSTGRES_ENABLED=true
AGRITECH_AI_ENABLED=true

# --- Sources ---
# Enable AgFunder in Docker; run Inc42 separately on Mac with AGRITECH_INC42_BROWSER_ENABLED=true
AGRITECH_AGFUNDER_ENABLED=true
AGRITECH_INC42_ENABLED=false
AGRITECH_INC42_BROWSER_ENABLED=false

# --- Scheduling ---
AGRITECH_DEFAULT_INTERVAL_MS=604800000
JOB_STAGGER_DELAY_MS=120000
AGRITECH_RUN_ONCE=false
AGRITECH_BROWSER_FALLBACK_ENABLED=false
AGENT_BROWSER_HEADED=true

# --- PostgreSQL (app container uses service name postgres) ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=agritech
DB_USER=postgres
DB_PASS=secret
DB_SCHEMA=agritech
DB_SSL=false
DB_MAX_POOL_SIZE=10
DB_MIN_POOL_SIZE=2
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000
POSTGRES_HOST_PORT=5432

# --- Ollama on host Mac ---
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

MAX_ITEMS_SCANNED_PER_RUN=50
MAX_NEW_ROWS_PER_RUN=20
MAX_SECTIONS_PER_RUN=10

AGRITECH_RUNS_DIR=./data/runs
AGRITECH_URL_CONTENT_INDEX=./data/url-content-index.json
AGRITECH_SECTION_SNAPSHOTS=./data/section-snapshots.json
AGRITECH_PROFILES_ROOT=./profiles
