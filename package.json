{
  "name": "agritech-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "AgriTech startup discovery tracker — AgFunderNews crawl + Ollama extraction. Fully standalone, no private registry dependencies.",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon",
    "dev:once": "AGRITECH_RUN_ONCE=true ts-node src/index.ts",
    "inc42:login": "bash scripts/inc42-login.sh",
    "test": "jest",
    "db:migrate": "node --env-file=.env scripts/run-migration.mjs"
  },
  "dependencies": {
    "agent-browser": "^0.25.5",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.16",
    "@types/pg": "^8.11.6",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  }
}
